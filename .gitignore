# =============================================================================
# IDE
# =============================================================================
.idea/
.vscode/
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db

# =============================================================================
# Secrets and local config (never commit these)
# =============================================================================
.env.local
.env.*.local
infra/cdk/config/environments.ts

# =============================================================================
# Go
# =============================================================================
# Binaries (Lambda/shared build output only — does not apply to infra/cdk/bin/)
lambdas/**/bin/
shared/**/bin/
**/*.exe
**/*.exe~
**/*.dll
**/*.so
**/*.dylib

# Test artifacts
**/*.test
**/*.out
**/coverage.out
**/coverage.html

# Go workspace (if using go work)
go.work.sum

# =============================================================================
# CDK / TypeScript
# =============================================================================
node_modules/
infra/cdk/cdk.out/
infra/cdk/*.js
infra/cdk/*.d.ts
infra/cdk/**/*.js
infra/cdk/**/*.d.ts

# CDK assets and staging
cdk.context.json

# =============================================================================
# Angular
# =============================================================================
frontend/angular/node_modules/
frontend/angular/dist/
frontend/angular/.angular/
frontend/angular/*.js.map
frontend/angular/storybook-static/
frontend/angular/storybook.log

# =============================================================================
# Playwright
# =============================================================================
test-results/
playwright-report/

# =============================================================================
# Lambda build artifacts
# =============================================================================
lambdas/**/bootstrap
lambdas/**/handler
lambdas/**/*.zip

# =============================================================================
# LocalStack
# =============================================================================
.localstack/
volume/

# =============================================================================
# Terraform (if ever added)
# =============================================================================
*.tfvars
*.tfvars.json
**/.terraform/
*.tfstate
*.tfstate.backup
