#!/usr/bin/env bash
# pre-push — mirrors the CI pipeline jobs so failures are caught locally.
#
# Runs four job groups in parallel (same as CI):
#   backend      — Go unit tests + vet  (golangci-lint skipped if not installed)
#   infrastructure — CDK tsc + jest
#   frontend     — Angular lint + build + karma unit tests + Playwright E2E
#   storybook    — Storybook production build
#
# Each job writes its output to a temp file and exits with the job's status.
# All jobs run concurrently; the hook fails if any job fails.

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
TMPDIR_HOOK="$(mktemp -d)"
trap 'rm -rf "${TMPDIR_HOOK}"' EXIT

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

log()  { echo -e "${BOLD}[pre-push]${RESET} $*"; }
pass() { echo -e "${GREEN}✔${RESET} $*"; }
fail() { echo -e "${RED}✘${RESET} $*"; }
warn() { echo -e "${YELLOW}⚠${RESET} $*"; }

# ── Job runner ────────────────────────────────────────────────────────────────
# run_job <name> <log-file> <cmd...>
# Runs cmd in the background; writes stdout+stderr to log-file.
# Stores the PID so we can wait for it later.
declare -A JOB_PIDS
declare -A JOB_LOGS

run_job() {
  local name="$1"; local logfile="$2"; shift 2
  "$@" >"${logfile}" 2>&1 &
  JOB_PIDS["${name}"]=$!
  JOB_LOGS["${name}"]="${logfile}"
}

# ── Jobs ──────────────────────────────────────────────────────────────────────

log "Running CI checks before push...\n"

# 1. Backend — Go unit tests + vet
run_job "backend" "${TMPDIR_HOOK}/backend.log" bash -c "
  set -euo pipefail
  cd '${ROOT}'
  make test-unit
  # golangci-lint is optional locally; CI installs it via script
  if command -v golangci-lint &>/dev/null; then
    make lint
  else
    echo 'golangci-lint not installed — skipping lint (CI will catch it)'
  fi
"

# 2. Infrastructure — CDK TypeScript check + unit tests
run_job "infrastructure" "${TMPDIR_HOOK}/infra.log" bash -c "
  set -euo pipefail
  cd '${ROOT}/infra/cdk'
  npx tsc --noEmit
  npm test
"

# 3. Frontend — lint + build + unit tests + E2E
run_job "frontend" "${TMPDIR_HOOK}/frontend.log" bash -c "
  set -euo pipefail
  cd '${ROOT}'
  make ng-lint
  make ng-build
  cd frontend/angular
  npx ng test --watch=false --browsers=ChromeHeadlessNoSandbox
  npx playwright test
"

# 4. Storybook — production build
run_job "storybook" "${TMPDIR_HOOK}/storybook.log" bash -c "
  set -euo pipefail
  cd '${ROOT}/frontend/angular'
  npm run storybook:build
"

# ── Wait and report ───────────────────────────────────────────────────────────

FAILED=()

for name in backend infrastructure frontend storybook; do
  pid="${JOB_PIDS[${name}]}"
  logfile="${JOB_LOGS[${name}]}"
  if wait "${pid}"; then
    pass "${name}"
  else
    fail "${name}"
    FAILED+=("${name}")
    echo ""
    echo -e "${RED}── ${name} output ──────────────────────────────────────────${RESET}"
    cat "${logfile}"
    echo -e "${RED}────────────────────────────────────────────────────────────${RESET}"
    echo ""
  fi
done

echo ""
if [[ ${#FAILED[@]} -eq 0 ]]; then
  pass "All checks passed. Push proceeding."
  exit 0
else
  fail "Failed: ${FAILED[*]}"
  log "Fix the errors above and retry."
  exit 1
fi
