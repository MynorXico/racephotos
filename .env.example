# =============================================================================
# .env.example — committed placeholder
#
# Copy to .env.local and fill in real values for your environment.
# .env.local is gitignored and must never be committed.
#
# For local development with LocalStack, the defaults below work as-is.
# Run `make seed-local` after `docker-compose up -d` to create all resources.
# =============================================================================

# ── Runtime environment ───────────────────────────────────────────────────────
RACEPHOTOS_ENV=local

# ── S3 buckets (created by seed-local.sh) ────────────────────────────────────
RACEPHOTOS_RAW_BUCKET=racephotos-raw-local
RACEPHOTOS_PROCESSED_BUCKET=racephotos-processed-local

# ── DynamoDB ──────────────────────────────────────────────────────────────────
RACEPHOTOS_TABLE_NAME=racephotos-photos-local

# ── SQS (created by seed-local.sh) ───────────────────────────────────────────
RACEPHOTOS_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/racephotos-processing-local

# ── Rekognition (not available in LocalStack — use file-backed mock) ──────────
# When RACEPHOTOS_ENV=local, the processor Lambda uses testdata/ responses.
RACEPHOTOS_CONFIDENCE_MIN=0.80

# ── AWS credentials for LocalStack ───────────────────────────────────────────
# These fake credentials are accepted by LocalStack. Do not use real credentials here.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# ── SES (email) — RS-003 ─────────────────────────────────────────────────────
# LocalStack CE supports SES in sandbox mode. All emails are captured, not sent.
# seed-local.sh reads RACEPHOTOS_SES_FROM_ADDRESS to verify the sender identity
# and seed the /racephotos/env/local/ses-from-address SSM parameter.
RACEPHOTOS_SES_FROM_ADDRESS=noreply@example.com

# ── Frontend API base URL (used when running Angular dev server) ──────────────
# The Angular app reads this from src/assets/config.json, not from here.
# See docs/setup/runtime-config.md and docs/setup/local-dev.md.
FRONTEND_API_BASE_URL=http://localhost:3000
